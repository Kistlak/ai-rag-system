# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Dependencies ──────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js ───────────────────────────────────────────────────
/.next/
/out/
/build
next-env.d.ts

# ── TypeScript ────────────────────────────────────────────────
*.tsbuildinfo

# ── Environment & secrets ─────────────────────────────────────
.env*
!.env.example

# ── Vercel ────────────────────────────────────────────────────
.vercel

# ── Testing ───────────────────────────────────────────────────
/coverage
.nyc_output

# ── Logs ──────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
logs

# ── Caches ────────────────────────────────────────────────────
.cache/
.turbo/
.eslintcache
.parcel-cache

# ── Editors / IDEs ────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~

# ── OS files ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*.pem

# ── Claude Code (local-only) ──────────────────────────────────
.claude/

# ── Project scratch / temp ────────────────────────────────────
_tmp/
tmp/
.scratch/

# Claude / AI agent state
#.agent/
.claude/
