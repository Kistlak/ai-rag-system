ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
PINECONE_API_KEY=...
PINECONE_INDEX=bbc-news
CRON_SECRET=any-long-random-string

# Optional — enables JS rendering via Cloudflare Browser Rendering
# Needed for JS-rendered SPAs (e.g. TMDB, Netflix) and some bot-protected sites
# Get these from: https://dash.cloudflare.com → Workers & Pages → Browser Rendering
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_BROWSER_TOKEN=

# Optional — if crawling your own Cloudflare-protected site
# Set this to a secret string, then create a WAF Custom Rule on your site:
#   IF header "x-internal-token" equals this value → Skip Bot Fight Mode
CLOUDFLARE_BYPASS_TOKEN=

# Optional — Upstash Redis for distributed rate limiting (recommended in prod)
# Without these, an in-memory fallback is used (works in dev, breaks across serverless instances)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
